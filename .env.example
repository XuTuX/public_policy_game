# Flutter Web 빌드에 포함해도 되는 공개 설정만 기록합니다.
# 이 파일은 앱에서 자동 로드되지 않습니다. 아래 값을 --dart-define으로 전달하세요.
USE_MOCK_DATA=true
PUBLIC_APP_URL=https://example.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# ASSEMBLY_API_KEY, DEEPSEEK_API_KEY 같은 비밀값은 웹 프로젝트에 두지 말고
# 별도 백엔드/서버리스 함수의 secret 저장소에서 관리합니다.
